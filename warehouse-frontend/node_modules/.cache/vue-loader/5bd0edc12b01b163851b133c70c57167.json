{"remainingRequest":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\product\\Category.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\product\\Category.vue","mtime":1773701863829},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773020855054},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773020855508}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Category.vue"],"names":[],"mappings":";AAqEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Category.vue","sourceRoot":"src/views/product","sourcesContent":["<template>\n  <div class=\"page-shell\">\n    <div class=\"page-header\">\n      <div>\n        <h2>品类管理</h2>\n        <p>维护商品品类、排序、状态与备注信息。</p>\n      </div>\n      <div class=\"soft-tag\">商品主数据</div>\n    </div>\n\n    <el-card class=\"data-card\">\n      <div class=\"panel-toolbar\">\n        <div class=\"left-tools\">\n          <el-input v-model=\"searchName\" clearable placeholder=\"搜索品类名称\" style=\"width: 220px;\" @keyup.enter.native=\"handleSearch\" />\n          <el-button type=\"primary\" icon=\"el-icon-search\" @click=\"handleSearch\">查询</el-button>\n        </div>\n        <div class=\"right-tools\" v-if=\"isAdmin\">\n          <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"handleAdd\">新增品类</el-button>\n        </div>\n      </div>\n\n      <el-table :data=\"tableData\" stripe v-loading=\"loading\">\n        <el-table-column prop=\"categoryName\" label=\"品类名称\" min-width=\"160\" />\n        <el-table-column prop=\"sort\" label=\"排序\" width=\"90\" />\n        <el-table-column prop=\"remark\" label=\"备注\" min-width=\"220\" show-overflow-tooltip />\n        <el-table-column label=\"状态\" width=\"100\">\n          <template slot-scope=\"{ row }\">\n            <el-tag :type=\"row.status === 1 ? 'success' : 'info'\">{{ row.status === 1 ? '启用' : '禁用' }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column v-if=\"isAdmin\" label=\"操作\" width=\"170\">\n          <template slot-scope=\"{ row }\">\n            <el-button type=\"text\" @click=\"handleEdit(row)\">编辑</el-button>\n            <el-button type=\"text\" style=\"color:#dc2626;\" @click=\"handleDelete(row.id)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <el-pagination\n        style=\"margin-top:18px;text-align:right;\"\n        layout=\"total, prev, pager, next\"\n        :current-page.sync=\"current\"\n        :page-size=\"size\"\n        :total=\"total\"\n        @current-change=\"loadData\"\n      />\n    </el-card>\n\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"560px\">\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"90px\">\n        <el-form-item label=\"品类名称\" prop=\"categoryName\"><el-input v-model=\"form.categoryName\" /></el-form-item>\n        <el-form-item label=\"排序\"><el-input-number v-model=\"form.sort\" :min=\"0\" /></el-form-item>\n        <el-form-item label=\"备注\"><el-input v-model=\"form.remark\" type=\"textarea\" /></el-form-item>\n        <el-form-item label=\"状态\">\n          <el-radio-group v-model=\"form.status\">\n            <el-radio :label=\"1\">启用</el-radio>\n            <el-radio :label=\"0\">禁用</el-radio>\n          </el-radio-group>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\">保存</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport request from '@/utils/request'\nimport { mapGetters } from 'vuex'\n\nexport default {\n  name: 'Category',\n  data() {\n    return {\n      searchName: '',\n      loading: false,\n      current: 1,\n      size: 10,\n      total: 0,\n      tableData: [],\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {},\n      rules: {\n        categoryName: [{ required: true, message: '请输入品类名称', trigger: 'blur' }]\n      }\n    }\n  },\n  computed: {\n    ...mapGetters(['isAdmin'])\n  },\n  created() {\n    this.loadData()\n  },\n  methods: {\n    async loadData() {\n      this.loading = true\n      try {\n        const res = await request.get('/category/page', {\n          params: { current: this.current, size: this.size, categoryName: this.searchName }\n        })\n        this.tableData = res.data.records\n        this.total = res.data.total\n      } finally {\n        this.loading = false\n      }\n    },\n    handleSearch() {\n      this.current = 1\n      this.loadData()\n    },\n    handleAdd() {\n      this.dialogTitle = '新增品类'\n      this.form = { status: 1, sort: 0 }\n      this.dialogVisible = true\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑品类'\n      this.form = { ...row }\n      this.dialogVisible = true\n    },\n    handleDelete(id) {\n      this.$confirm('确认删除该品类吗？', '提示', { type: 'warning' }).then(async () => {\n        await request.delete(`/category/${id}`)\n        this.$message.success('删除成功')\n        this.loadData()\n      }).catch(() => {})\n    },\n    handleSubmit() {\n      this.$refs.form.validate(async valid => {\n        if (!valid) return\n        if (this.form.id) {\n          await request.put('/category', this.form)\n          this.$message.success('品类已更新')\n        } else {\n          await request.post('/category', this.form)\n          this.$message.success('品类已创建')\n        }\n        this.dialogVisible = false\n        this.loadData()\n      })\n    }\n  }\n}\n</script>\n"]}]}