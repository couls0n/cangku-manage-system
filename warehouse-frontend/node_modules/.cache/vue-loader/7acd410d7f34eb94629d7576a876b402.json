{"remainingRequest":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\partner\\Supplier.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\partner\\Supplier.vue","mtime":1773701942890},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773020855054},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773020855508}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Supplier.vue"],"names":[],"mappings":";AAwEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Supplier.vue","sourceRoot":"src/views/partner","sourcesContent":["<template>\n  <div class=\"page-shell\">\n    <div class=\"page-header\">\n      <div>\n        <h2>供应商管理</h2>\n        <p>维护供应商档案、联系方式和合作状态。</p>\n      </div>\n      <div class=\"soft-tag\">合作伙伴</div>\n    </div>\n\n    <el-card class=\"data-card\">\n      <div class=\"panel-toolbar\">\n        <div class=\"left-tools\">\n          <el-input v-model=\"searchName\" clearable placeholder=\"搜索供应商名称\" style=\"width:220px;\" @keyup.enter.native=\"handleSearch\" />\n          <el-button type=\"primary\" icon=\"el-icon-search\" @click=\"handleSearch\">查询</el-button>\n        </div>\n        <div class=\"right-tools\" v-if=\"isAdmin\">\n          <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"handleAdd\">新增供应商</el-button>\n        </div>\n      </div>\n\n      <el-table :data=\"tableData\" stripe v-loading=\"loading\">\n        <el-table-column prop=\"supplierCode\" label=\"供应商编码\" min-width=\"120\" />\n        <el-table-column prop=\"supplierName\" label=\"供应商名称\" min-width=\"160\" />\n        <el-table-column prop=\"contactPerson\" label=\"联系人\" min-width=\"120\" />\n        <el-table-column prop=\"phone\" label=\"手机号\" min-width=\"130\" />\n        <el-table-column prop=\"email\" label=\"邮箱\" min-width=\"180\" />\n        <el-table-column label=\"状态\" width=\"100\">\n          <template slot-scope=\"{ row }\">\n            <el-tag :type=\"row.status === 1 ? 'success' : 'info'\">{{ row.status === 1 ? '启用' : '禁用' }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column v-if=\"isAdmin\" label=\"操作\" width=\"170\">\n          <template slot-scope=\"{ row }\">\n            <el-button type=\"text\" @click=\"handleEdit(row)\">编辑</el-button>\n            <el-button type=\"text\" style=\"color:#dc2626;\" @click=\"handleDelete(row.id)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <el-pagination style=\"margin-top:18px;text-align:right;\" layout=\"total, prev, pager, next\" :current-page.sync=\"current\" :page-size=\"size\" :total=\"total\" @current-change=\"loadData\" />\n    </el-card>\n\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"620px\">\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"90px\">\n        <el-row :gutter=\"14\">\n          <el-col :span=\"12\"><el-form-item label=\"编码\" prop=\"supplierCode\"><el-input v-model=\"form.supplierCode\" /></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"名称\" prop=\"supplierName\"><el-input v-model=\"form.supplierName\" /></el-form-item></el-col>\n        </el-row>\n        <el-row :gutter=\"14\">\n          <el-col :span=\"12\"><el-form-item label=\"联系人\"><el-input v-model=\"form.contactPerson\" /></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"手机号\"><el-input v-model=\"form.phone\" /></el-form-item></el-col>\n        </el-row>\n        <el-form-item label=\"邮箱\"><el-input v-model=\"form.email\" /></el-form-item>\n        <el-form-item label=\"地址\"><el-input v-model=\"form.address\" /></el-form-item>\n        <el-form-item label=\"备注\"><el-input v-model=\"form.remark\" type=\"textarea\" /></el-form-item>\n        <el-form-item label=\"状态\">\n          <el-radio-group v-model=\"form.status\">\n            <el-radio :label=\"1\">启用</el-radio>\n            <el-radio :label=\"0\">禁用</el-radio>\n          </el-radio-group>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\">保存</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport request from '@/utils/request'\nimport { mapGetters } from 'vuex'\n\nexport default {\n  name: 'Supplier',\n  data() {\n    return {\n      searchName: '',\n      loading: false,\n      current: 1,\n      size: 10,\n      total: 0,\n      tableData: [],\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {},\n      rules: {\n        supplierCode: [{ required: true, message: '请输入供应商编码', trigger: 'blur' }],\n        supplierName: [{ required: true, message: '请输入供应商名称', trigger: 'blur' }]\n      }\n    }\n  },\n  computed: {\n    ...mapGetters(['isAdmin'])\n  },\n  created() {\n    this.loadData()\n  },\n  methods: {\n    async loadData() {\n      this.loading = true\n      try {\n        const res = await request.get('/supplier/page', {\n          params: { current: this.current, size: this.size, supplierName: this.searchName }\n        })\n        this.tableData = res.data.records\n        this.total = res.data.total\n      } finally {\n        this.loading = false\n      }\n    },\n    handleSearch() {\n      this.current = 1\n      this.loadData()\n    },\n    handleAdd() {\n      this.dialogTitle = '新增供应商'\n      this.form = { status: 1 }\n      this.dialogVisible = true\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑供应商'\n      this.form = { ...row }\n      this.dialogVisible = true\n    },\n    handleDelete(id) {\n      this.$confirm('确认删除该供应商吗？', '提示', { type: 'warning' }).then(async () => {\n        await request.delete(`/supplier/${id}`)\n        this.$message.success('删除成功')\n        this.loadData()\n      }).catch(() => {})\n    },\n    handleSubmit() {\n      this.$refs.form.validate(async valid => {\n        if (!valid) return\n        if (this.form.id) {\n          await request.put('/supplier', this.form)\n          this.$message.success('供应商已更新')\n        } else {\n          await request.post('/supplier', this.form)\n          this.$message.success('供应商已创建')\n        }\n        this.dialogVisible = false\n        this.loadData()\n      })\n    }\n  }\n}\n</script>\n"]}]}