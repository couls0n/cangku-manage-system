{"remainingRequest":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\product\\Product.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\product\\Product.vue","mtime":1773701942888},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773020855054},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773020855508}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Product.vue"],"names":[],"mappings":";AAiGA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Product.vue","sourceRoot":"src/views/product","sourcesContent":["<template>\n  <div class=\"page-shell\">\n    <div class=\"page-header\">\n      <div>\n        <h2>商品管理</h2>\n        <p>维护商品档案、品类、品牌、规格、价格与启停状态。</p>\n      </div>\n      <div class=\"soft-tag\">商品台账</div>\n    </div>\n\n    <el-card class=\"data-card\">\n      <div class=\"panel-toolbar\">\n        <div class=\"left-tools\">\n          <el-input v-model=\"searchName\" clearable placeholder=\"搜索商品名称\" style=\"width: 220px;\" @keyup.enter.native=\"handleSearch\" />\n          <el-select v-model=\"searchCategoryId\" clearable filterable placeholder=\"筛选品类\" style=\"width: 180px;\">\n            <el-option v-for=\"item in categoryList\" :key=\"item.id\" :label=\"item.categoryName\" :value=\"item.id\" />\n          </el-select>\n          <el-button type=\"primary\" icon=\"el-icon-search\" @click=\"handleSearch\">查询</el-button>\n        </div>\n        <div class=\"right-tools\" v-if=\"isAdmin\">\n          <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"handleAdd\">新增商品</el-button>\n        </div>\n      </div>\n\n      <el-table :data=\"tableData\" stripe v-loading=\"loading\">\n        <el-table-column prop=\"productCode\" label=\"商品编码\" min-width=\"120\" />\n        <el-table-column prop=\"productName\" label=\"商品名称\" min-width=\"160\" />\n        <el-table-column prop=\"categoryName\" label=\"品类\" min-width=\"120\" />\n        <el-table-column prop=\"brand\" label=\"品牌\" min-width=\"110\" />\n        <el-table-column prop=\"specification\" label=\"规格\" min-width=\"120\" />\n        <el-table-column prop=\"unit\" label=\"单位\" width=\"80\" />\n        <el-table-column prop=\"price\" label=\"单价\" width=\"100\" />\n        <el-table-column label=\"状态\" width=\"100\">\n          <template slot-scope=\"{ row }\">\n            <el-tag :type=\"row.status === 1 ? 'success' : 'info'\">{{ row.status === 1 ? '启用' : '禁用' }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column v-if=\"isAdmin\" label=\"操作\" width=\"170\">\n          <template slot-scope=\"{ row }\">\n            <el-button type=\"text\" @click=\"handleEdit(row)\">编辑</el-button>\n            <el-button type=\"text\" style=\"color:#dc2626;\" @click=\"handleDelete(row.id)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <el-pagination\n        style=\"margin-top:18px;text-align:right;\"\n        layout=\"total, prev, pager, next\"\n        :current-page.sync=\"current\"\n        :page-size=\"size\"\n        :total=\"total\"\n        @current-change=\"loadData\"\n      />\n    </el-card>\n\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"680px\">\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"90px\">\n        <el-row :gutter=\"14\">\n          <el-col :span=\"12\"><el-form-item label=\"商品编码\" prop=\"productCode\"><el-input v-model=\"form.productCode\" /></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"商品名称\" prop=\"productName\"><el-input v-model=\"form.productName\" /></el-form-item></el-col>\n        </el-row>\n        <el-row :gutter=\"14\">\n          <el-col :span=\"12\">\n            <el-form-item label=\"品类\" prop=\"categoryId\">\n              <el-select v-model=\"form.categoryId\" filterable style=\"width:100%;\">\n                <el-option v-for=\"item in categoryList\" :key=\"item.id\" :label=\"item.categoryName\" :value=\"item.id\" />\n              </el-select>\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\"><el-form-item label=\"品牌\"><el-input v-model=\"form.brand\" /></el-form-item></el-col>\n        </el-row>\n        <el-row :gutter=\"14\">\n          <el-col :span=\"12\"><el-form-item label=\"规格\"><el-input v-model=\"form.specification\" /></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"单位\"><el-input v-model=\"form.unit\" /></el-form-item></el-col>\n        </el-row>\n        <el-row :gutter=\"14\">\n          <el-col :span=\"12\"><el-form-item label=\"单价\"><el-input-number v-model=\"form.price\" :min=\"0\" :precision=\"2\" style=\"width:100%;\" /></el-form-item></el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"状态\">\n              <el-radio-group v-model=\"form.status\">\n                <el-radio :label=\"1\">启用</el-radio>\n                <el-radio :label=\"0\">禁用</el-radio>\n              </el-radio-group>\n            </el-form-item>\n          </el-col>\n        </el-row>\n        <el-form-item label=\"备注\"><el-input v-model=\"form.remark\" type=\"textarea\" /></el-form-item>\n      </el-form>\n      <span slot=\"footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\">保存</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport request from '@/utils/request'\nimport { mapGetters } from 'vuex'\n\nexport default {\n  name: 'Product',\n  data() {\n    return {\n      searchName: '',\n      searchCategoryId: null,\n      categoryList: [],\n      tableData: [],\n      loading: false,\n      current: 1,\n      size: 10,\n      total: 0,\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {},\n      rules: {\n        productCode: [{ required: true, message: '请输入商品编码', trigger: 'blur' }],\n        productName: [{ required: true, message: '请输入商品名称', trigger: 'blur' }],\n        categoryId: [{ required: true, message: '请选择品类', trigger: 'change' }]\n      }\n    }\n  },\n  computed: {\n    ...mapGetters(['isAdmin'])\n  },\n  created() {\n    this.loadCategory()\n    this.loadData()\n  },\n  methods: {\n    async loadCategory() {\n      const res = await request.get('/category/list')\n      this.categoryList = res.data\n    },\n    async loadData() {\n      this.loading = true\n      try {\n        const res = await request.get('/product/page', {\n          params: {\n            current: this.current,\n            size: this.size,\n            productName: this.searchName,\n            categoryId: this.searchCategoryId\n          }\n        })\n        this.tableData = res.data.records.map(item => ({\n          ...item,\n          categoryName: (this.categoryList.find(category => category.id === item.categoryId) || {}).categoryName || ''\n        }))\n        this.total = res.data.total\n      } finally {\n        this.loading = false\n      }\n    },\n    handleSearch() {\n      this.current = 1\n      this.loadData()\n    },\n    handleAdd() {\n      this.dialogTitle = '新增商品'\n      this.form = { status: 1, price: 0 }\n      this.dialogVisible = true\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑商品'\n      this.form = { ...row }\n      this.dialogVisible = true\n    },\n    handleDelete(id) {\n      this.$confirm('确认删除该商品吗？', '提示', { type: 'warning' }).then(async () => {\n        await request.delete(`/product/${id}`)\n        this.$message.success('删除成功')\n        this.loadData()\n      }).catch(() => {})\n    },\n    handleSubmit() {\n      this.$refs.form.validate(async valid => {\n        if (!valid) return\n        if (this.form.id) {\n          await request.put('/product', this.form)\n          this.$message.success('商品已更新')\n        } else {\n          await request.post('/product', this.form)\n          this.$message.success('商品已创建')\n        }\n        this.dialogVisible = false\n        this.loadData()\n      })\n    }\n  }\n}\n</script>\n"]}]}