{"remainingRequest":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\order\\Outbound.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\order\\Outbound.vue","mtime":1773702111423},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773020855054},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773020855508}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Outbound.vue"],"names":[],"mappings":";AAwEA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Outbound.vue","sourceRoot":"src/views/order","sourcesContent":["<template>\n  <div class=\"page-shell\">\n    <div class=\"page-header\">\n      <div>\n        <h2>出库单管理</h2>\n        <p>登记出库订单、客户、仓库和发货状态。</p>\n      </div>\n      <div class=\"soft-tag\">销售出库流程</div>\n    </div>\n\n    <el-card class=\"data-card\">\n      <div class=\"panel-toolbar\">\n        <div class=\"left-tools\">\n          <el-input v-model=\"searchOrderNo\" clearable placeholder=\"搜索出库单号\" style=\"width:220px;\" @keyup.enter.native=\"handleSearch\" />\n          <el-select v-model=\"searchWarehouseId\" clearable placeholder=\"筛选仓库\" style=\"width:180px;\">\n            <el-option v-for=\"item in warehouseList\" :key=\"item.id\" :label=\"item.warehouseName\" :value=\"item.id\" />\n          </el-select>\n          <el-button type=\"primary\" icon=\"el-icon-search\" @click=\"handleSearch\">查询</el-button>\n        </div>\n        <div class=\"right-tools\">\n          <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"handleAdd\">新增出库单</el-button>\n        </div>\n      </div>\n\n      <el-table :data=\"tableData\" stripe v-loading=\"loading\">\n        <el-table-column prop=\"orderNo\" label=\"出库单号\" min-width=\"150\" />\n        <el-table-column prop=\"warehouseName\" label=\"仓库\" min-width=\"140\" />\n        <el-table-column prop=\"customerName\" label=\"客户\" min-width=\"160\" />\n        <el-table-column prop=\"totalAmount\" label=\"总金额\" width=\"110\" />\n        <el-table-column prop=\"orderTime\" label=\"出库时间\" width=\"170\" />\n        <el-table-column label=\"状态\" width=\"100\">\n          <template slot-scope=\"{ row }\">\n            <el-tag :type=\"statusType(row.status)\">{{ statusText(row.status) }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"220\">\n          <template slot-scope=\"{ row }\">\n            <el-button type=\"text\" @click=\"handleEdit(row)\" v-if=\"row.status !== 1\">编辑</el-button>\n            <el-button type=\"text\" style=\"color:#16a34a;\" @click=\"handleConfirm(row)\" v-if=\"row.status === 0\">确认</el-button>\n            <el-button type=\"text\" style=\"color:#dc2626;\" @click=\"handleDelete(row.id)\" v-if=\"row.status !== 1\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <el-pagination style=\"margin-top:18px;text-align:right;\" layout=\"total, prev, pager, next\" :current-page.sync=\"current\" :page-size=\"size\" :total=\"total\" @current-change=\"loadData\" />\n    </el-card>\n\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"680px\">\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"90px\">\n        <el-row :gutter=\"14\">\n          <el-col :span=\"12\"><el-form-item label=\"出库单号\" prop=\"orderNo\"><el-input v-model=\"form.orderNo\" /></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"仓库\" prop=\"warehouseId\"><el-select v-model=\"form.warehouseId\" style=\"width:100%;\"><el-option v-for=\"item in warehouseList\" :key=\"item.id\" :label=\"item.warehouseName\" :value=\"item.id\" /></el-select></el-form-item></el-col>\n        </el-row>\n        <el-row :gutter=\"14\">\n          <el-col :span=\"12\"><el-form-item label=\"客户\" prop=\"customerId\"><el-select v-model=\"form.customerId\" style=\"width:100%;\"><el-option v-for=\"item in customerList\" :key=\"item.id\" :label=\"item.customerName\" :value=\"item.id\" /></el-select></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"总金额\"><el-input-number v-model=\"form.totalAmount\" :min=\"0\" :precision=\"2\" style=\"width:100%;\" /></el-form-item></el-col>\n        </el-row>\n        <el-row :gutter=\"14\">\n          <el-col :span=\"12\"><el-form-item label=\"出库时间\"><el-date-picker v-model=\"form.orderTime\" type=\"datetime\" style=\"width:100%;\" value-format=\"yyyy-MM-dd HH:mm:ss\" /></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"状态\"><el-select v-model=\"form.status\" style=\"width:100%;\"><el-option label=\"待确认\" :value=\"0\" /><el-option label=\"已完成\" :value=\"1\" /><el-option label=\"已取消\" :value=\"2\" /></el-select></el-form-item></el-col>\n        </el-row>\n        <el-form-item label=\"备注\"><el-input v-model=\"form.remark\" type=\"textarea\" /></el-form-item>\n      </el-form>\n      <span slot=\"footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\">保存</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport request from '@/utils/request'\n\nexport default {\n  name: 'Outbound',\n  data() {\n    return {\n      searchOrderNo: '',\n      searchWarehouseId: null,\n      warehouseList: [],\n      customerList: [],\n      tableData: [],\n      loading: false,\n      current: 1,\n      size: 10,\n      total: 0,\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {},\n      rules: {\n        orderNo: [{ required: true, message: '请输入出库单号', trigger: 'blur' }],\n        warehouseId: [{ required: true, message: '请选择仓库', trigger: 'change' }]\n      }\n    }\n  },\n  created() {\n    this.bootstrap()\n  },\n  methods: {\n    statusType(status) {\n      return { 0: 'warning', 1: 'success', 2: 'info' }[status] || 'info'\n    },\n    statusText(status) {\n      return { 0: '待确认', 1: '已完成', 2: '已取消' }[status] || '未知'\n    },\n    async bootstrap() {\n      await Promise.all([this.loadWarehouse(), this.loadCustomer()])\n      this.loadData()\n    },\n    async loadWarehouse() {\n      const res = await request.get('/warehouse/list')\n      this.warehouseList = res.data\n    },\n    async loadCustomer() {\n      const res = await request.get('/customer/list')\n      this.customerList = res.data\n    },\n    async loadData() {\n      this.loading = true\n      try {\n        const res = await request.get('/outbound/page', {\n          params: { current: this.current, size: this.size, orderNo: this.searchOrderNo, warehouseId: this.searchWarehouseId }\n        })\n        this.tableData = res.data.records.map(item => ({\n          ...item,\n          warehouseName: (this.warehouseList.find(warehouse => warehouse.id === item.warehouseId) || {}).warehouseName || '',\n          customerName: (this.customerList.find(customer => customer.id === item.customerId) || {}).customerName || ''\n        }))\n        this.total = res.data.total\n      } finally {\n        this.loading = false\n      }\n    },\n    handleSearch() {\n      this.current = 1\n      this.loadData()\n    },\n    handleAdd() {\n      this.dialogTitle = '新增出库单'\n      this.form = {\n        orderNo: `OUT${Date.now()}`,\n        status: 0,\n        totalAmount: 0,\n        orderTime: this.formatNow()\n      }\n      this.dialogVisible = true\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑出库单'\n      this.form = { ...row }\n      this.dialogVisible = true\n    },\n    handleConfirm(row) {\n      this.$confirm('确认将该出库单标记为已完成吗？', '提示', { type: 'warning' }).then(async () => {\n        await request.put('/outbound', { ...row, status: 1 })\n        this.$message.success('出库单已确认')\n        this.loadData()\n      }).catch(() => {})\n    },\n    handleDelete(id) {\n      this.$confirm('确认删除该出库单吗？', '提示', { type: 'warning' }).then(async () => {\n        await request.delete(`/outbound/${id}`)\n        this.$message.success('删除成功')\n        this.loadData()\n      }).catch(() => {})\n    },\n    handleSubmit() {\n      this.$refs.form.validate(async valid => {\n        if (!valid) return\n        if (this.form.id) {\n          await request.put('/outbound', this.form)\n          this.$message.success('出库单已更新')\n        } else {\n          await request.post('/outbound', this.form)\n          this.$message.success('出库单已创建')\n        }\n        this.dialogVisible = false\n        this.loadData()\n      })\n    },\n    formatNow() {\n      const date = new Date()\n      const pad = value => String(value).padStart(2, '0')\n      return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())} ${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())}`\n    }\n  }\n}\n</script>\n"]}]}