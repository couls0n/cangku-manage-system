{"remainingRequest":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\Login.vue?vue&type=style&index=0&id=560b41d6&prod&scoped=true&lang=css","dependencies":[{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\src\\views\\Login.vue","mtime":1773701676568},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\css-loader\\dist\\cjs.js","mtime":1773020855185},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1773020856071},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\postcss-loader\\src\\index.js","mtime":1773020855259},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773020855054},{"path":"D:\\Java_code\\cangku-manage-system\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773020855508}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Login.vue"],"names":[],"mappings":";AAkFA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA","file":"Login.vue","sourceRoot":"src/views","sourcesContent":["<template>\n  <div class=\"login-page\">\n    <div class=\"login-hero\">\n      <div class=\"badge\">仓储业务 + eBPF 安全联防</div>\n      <h1>仓储后台管理中心</h1>\n      <p>\n        将仓库、库存、订单、伙伴管理与安全监控整合到一个后台中。管理员可直接查看 API 越权拦截、频控告警和 eBPF\n        上报的系统异常事件。\n      </p>\n      <div class=\"hero-points\">\n        <span>统一身份令牌</span>\n        <span>水平 / 垂直越权防御</span>\n        <span>eBPF 异常行为可视化</span>\n      </div>\n    </div>\n\n    <el-card class=\"login-card data-card\">\n      <div class=\"login-title\">\n        <h2>登录系统</h2>\n        <p>默认管理员账号 `admin / 123456`</p>\n      </div>\n      <el-form ref=\"loginForm\" :model=\"loginForm\" :rules=\"rules\" @submit.native.prevent>\n        <el-form-item prop=\"username\">\n          <el-input v-model=\"loginForm.username\" prefix-icon=\"el-icon-user\" placeholder=\"请输入用户名\" />\n        </el-form-item>\n        <el-form-item prop=\"password\">\n          <el-input\n            v-model=\"loginForm.password\"\n            type=\"password\"\n            prefix-icon=\"el-icon-lock\"\n            placeholder=\"请输入密码\"\n            @keyup.enter.native=\"handleLogin\"\n          />\n        </el-form-item>\n        <el-button type=\"primary\" class=\"login-btn\" :loading=\"loading\" @click=\"handleLogin\">登录并进入后台</el-button>\n      </el-form>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport request from '@/utils/request'\n\nexport default {\n  name: 'Login',\n  data() {\n    return {\n      loading: false,\n      loginForm: {\n        username: 'admin',\n        password: '123456'\n      },\n      rules: {\n        username: [{ required: true, message: '请输入用户名', trigger: 'blur' }],\n        password: [{ required: true, message: '请输入密码', trigger: 'blur' }]\n      }\n    }\n  },\n  methods: {\n    handleLogin() {\n      this.$refs.loginForm.validate(async valid => {\n        if (!valid) {\n          return\n        }\n        this.loading = true\n        try {\n          const res = await request.post('/auth/login', this.loginForm)\n          this.$store.dispatch('login', res.data)\n          this.$message.success(`欢迎回来，${res.data.user.realName || res.data.user.username}`)\n          this.$router.push('/dashboard')\n        } catch (error) {\n          console.error(error)\n        } finally {\n          this.loading = false\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.login-page {\n  height: 100%;\n  display: grid;\n  grid-template-columns: 1.2fr 0.85fr;\n  gap: 28px;\n  padding: 36px;\n  background:\n    radial-gradient(circle at top left, rgba(8, 59, 102, 0.14), transparent 28%),\n    radial-gradient(circle at bottom right, rgba(217, 119, 6, 0.14), transparent 26%),\n    linear-gradient(135deg, #eef4fb, #f7f2eb);\n}\n\n.login-hero {\n  border-radius: 28px;\n  padding: 42px;\n  color: #fff;\n  background: linear-gradient(145deg, #082f49, #0f766e 55%, #d97706);\n  box-shadow: 0 28px 50px rgba(8, 47, 73, 0.25);\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n}\n\n.badge {\n  width: fit-content;\n  padding: 8px 14px;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.14);\n  font-size: 13px;\n  font-weight: 600;\n}\n\n.login-hero h1 {\n  margin: 22px 0 14px;\n  font-size: 48px;\n  line-height: 1.08;\n}\n\n.login-hero p {\n  margin: 0;\n  max-width: 620px;\n  color: rgba(255, 255, 255, 0.82);\n  line-height: 1.8;\n}\n\n.hero-points {\n  margin-top: 28px;\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n}\n\n.hero-points span {\n  padding: 10px 14px;\n  border-radius: 14px;\n  background: rgba(255, 255, 255, 0.12);\n}\n\n.login-card {\n  align-self: center;\n  padding: 24px;\n}\n\n.login-title h2 {\n  margin: 0;\n  font-size: 30px;\n}\n\n.login-title p {\n  margin: 8px 0 24px;\n  color: #6b7280;\n}\n\n.login-btn {\n  width: 100%;\n  height: 46px;\n  border-radius: 14px;\n  font-size: 15px;\n}\n</style>\n"]}]}